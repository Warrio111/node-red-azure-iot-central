{
  "name": "node-red-contrib-azure-iot-central",
  "version": "2.0.0",
  "description": "Node-RED node for Azure IoT Central — telemetry, commands, and device twin via MQTT/AMQP/HTTP using the official Azure IoT SDK",
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "azure-iot-device":                   "^1.18.4",
    "azure-iot-device-mqtt":              "^1.16.4",
    "azure-iot-device-amqp":              "^1.14.4",
    "azure-iot-device-http":              "^1.14.4",
    "azure-iot-provisioning-device":      "^1.9.2",
    "azure-iot-provisioning-device-mqtt": "^1.9.2",
    "azure-iot-security-symmetric-key":   "^1.9.2",
    "azure-iot-security-x509":            "^1.9.2"
  },
  "keywords": ["node-red", "azure", "iot", "iot-central", "mqtt", "dps", "provisioning"],
  "license": "MIT",
  "node-red": {
    "version": ">=3.0.0",
    "nodes": {
      "azure-iot-central": "nodes/azure-iot-central.js"
    }
  }
}
